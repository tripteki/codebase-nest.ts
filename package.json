{
    "name": "codebase",
    "version": "0.0.1",
    "description": "",
    "author": "Anonymous <anonymous@email.com>",
    "private": true,
    "license": "UNLICENSED",

    "scripts": {

        "documentation": "npx @compodoc/compodoc -p tsconfig.json -d public/documentation --hideDarkModeToggle --hideGenerator --disableDependencies --disableSourceCode --disableTemplateTab --disableStyleTab",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "build": "nest build",
        "start": "nest start",
        "start:development": "NODE_ENV=local nest start --debug --watch",
        "start:production": "NODE_ENV=production npx bun ./dist/main",
        "dev": "npm run start:development",
        "prod": "npm run build && npm run start:production",
        "lint": "npm run format && eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "npm run test:e2e",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --testRegex='\\.e2e-spec\\.ts$' --coverage",
        "migrator": "npx typeorm-ts-node-commonjs --dataSource ./src/app/drivers/driver.database.ts",
        "repl": "npm run start -- --watch --entryFile repl",
        "art": "node ./dist/cli.js",
        "art:migration:create": "npx typeorm-ts-node-commonjs migration:create",
        "art:migration:status": "npm run migrator migration:show",
        "art:migration:up": "npm run migrator migration:run",
        "art:migration:down": "npm run migrator migration:revert",
        "art:migration:reset": "npm run migrator schema:drop"
    },

    "strict": true,
    "engines": { "node": ">=20.15.0" },

    "dependencies": {

        "bun": "^1.1.29",
        "csrf-csrf": "^3.0.8",
        "helmet": "^8.0.0",
        "cors": "^2.8.5",
        "@nestjs-query/core": "^0.30.0",
        "@nestjs-query/query-graphql": "^0.30.0",
        "@nestjs-query/query-typeorm": "^0.30.0",
        "@nestjs/graphql": "^12.2.1",
        "@nestjs/apollo": "^12.2.1",
        "@apollo/server": "^4.11.2",
        "graphql": "^16.9.0",
        "graphql-subscriptions": "^2.0.0",
        "nest-commander": "^3.15.0",
        "nestjs-i18n": "^10.4.9",

        "nest-cluster-hub": "^0.4.0",
        "@nestjs/common": "^10.4.6",
        "@nestjs/event-emitter": "^2.1.1",
        "@nestjs/websockets": "^10.4.6",
        "@nestjs/platform-socket.io": "^10.4.6",
        "@nestjs/core": "^10.4.4",
        "@nestjs/platform-express": "^10.4.4",

        "@nestjs/config": "^3.1.1",
        "@nestjs/terminus": "^10.2.3",
        "@nestjs/throttler": "^6.2.1",
        "@nestjs/serve-static": "^4.0.0",
        "@nestjs/swagger": "^7.1.16",
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/cache-manager": "^2.1.1",
        "@nestjs/typeorm": "^10.0.2",
        "@sinuos/nestjs-hasher": "^1.1.1",
        "cache-manager": "^5.3.1",
        "cache-manager-redis-yet": "^4.1.2",
        "typeorm": "^0.3.20",
        "mongodb": "^5.9.2",
        "pg": "^8.13.0",
        "mysql2": "^3.11.3",
        "nest-winston": "^1.9.7",
        "winston": "^3.15.0",
        "winston-daily-rotate-file": "^5.0.0",
        "winston-elasticsearch": "^0.19.0",
        "nodemailer": "^6.9.15",
        "hbs": "^4.2.0",
        "@vicgutt/strjs": "^0.1.6",
        "underscore": "^1.13.7",
        "moment-timezone": "^0.5.46",
        "rxjs": "^7.8.1",
        "bson": "^6.2.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "dataloader": "^2.2.2",
        "reflect-metadata": "^0.2.1"
    },

    "devDependencies": {

        "@swc/core": "^1.4.0",
        "@swc/cli": "^0.3.9",
        "@compodoc/compodoc": "^1.1.23",
        "@faker-js/faker": "^8.3.1",
        "@nestjs/cli": "^10.4.5",
        "@nestjs/schematics": "^10.1.0",
        "@nestjs/testing": "^10.3.2",
        "@tripteki/eslint-config": "^1.3.12",
        "@tripteki/prettier-config": "^1.0.0",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.16",
        "@types/nodemailer": "^6.4.16",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "jest": "^29.7.0",
        "prettier": "^3.2.5",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.2",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    },

    "jest": {

        "moduleFileExtensions": [

            "yml",
            "json",
            "js",
            "ts"
        ],

        "rootDir": "src",
        "transform": { "^.+\\.(t|j)s$": "ts-jest" },
        "testEnvironment": "node",
        "testRegex": ".*\\.spec\\.ts$",
        "collectCoverageFrom": [ "**/*.(t|j)s" ],
        "coverageDirectory": "../coverage"
    }
}
