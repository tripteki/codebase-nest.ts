generator postgre {

    provider = "prisma-client-js"
    output   = "../../../node_modules/@prisma/postgre/client"
}

datasource postgre {

    provider = "postgresql"
    url      = env ("DATABASE_POSTGRE_URI")
}

model User {

    @@map ("users")

    id                  String      @id @default (uuid ())
    name                String      @unique
    email               String      @unique
    password            String
    email_verified_at   DateTime?
    created_at          DateTime
    updated_at          DateTime
    deleted_at          DateTime?
}
