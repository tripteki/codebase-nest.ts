generator postgre {

    provider = "prisma-client-js"
    // output   = "../../../node_modules/@prisma/postgre/client" //
}

datasource postgre {

    provider = "postgresql"
    url      = env ("DATABASE_POSTGRE_URI")
}

model User {

    @@map ("users")

    id                  String      @id
    name                String      @unique
    email               String      @unique
    password            String
    email_verified_at   DateTime?
    created_at          DateTime
    updated_at          DateTime
    deleted_at          DateTime?

    resetter            Resetter?
    notifications       Notification[]
    profile             Profile?
}

model PushSubscription {

    @@map ("push_subscriptions")
    @@index ([subscribable_type, subscribable_id], map: "subscribable_type_id_index")

    id                  BigInt      @id @default (autoincrement ())
    subscribable_id     String
    subscribable_type   String
    endpoint            String      @unique
    public_key          String?
    auth_token          String?
    content_encoding    String?
    created_at          DateTime
    updated_at          DateTime
}

model Profile {

    @@map ("profiles")

    id                  String      @id
    user_id             String      @unique
    full_name           String?
    avatar              String?
    interests           Json?
    created_at          DateTime
    updated_at          DateTime

    user                User        @relation (fields: [user_id], references: [id], onDelete: Cascade)
}

model Permission {

    @@map ("permissions")
    @@unique ([name, guard_name])

    id                  String      @id
    name                String
    guard_name          String
    created_at          DateTime
    updated_at          DateTime

    roles               RoleHasPermission[]
}

model Role {

    @@map ("roles")
    @@unique ([name, guard_name])

    id                  String      @id
    name                String
    guard_name          String
    created_at          DateTime
    updated_at          DateTime

    permissions         RoleHasPermission[]
    users               ModelHasRole[]
}

model RoleHasPermission {

    @@map ("role_has_permissions")

    permission_id       String
    role_id             String

    permission          Permission  @relation (fields: [permission_id], references: [id], onDelete: Cascade)
    role                Role        @relation (fields: [role_id], references: [id], onDelete: Cascade)

    @@id ([permission_id, role_id])
}

model ModelHasRole {

    @@map ("model_has_roles")
    @@index ([model_id, model_type], map: "model_has_roles_model_id_model_type_index")

    role_id             String
    model_type          String
    model_id            String

    role                Role        @relation (fields: [role_id], references: [id], onDelete: Cascade)

    @@id ([role_id, model_type, model_id])
}

model Resetter {

    @@map ("password_reset_tokens")

    token               String      @id
    email               String      @unique
    created_at          DateTime

    user                User        @relation (fields: [email], references: [email])
}

model Notification {

    @@map ("notifications")

    id                  String      @id
    user_id             String
    type                String
    data                Json
    read_at             DateTime?
    created_at          DateTime
    updated_at          DateTime
    deleted_at          DateTime?

    user                User        @relation (fields: [user_id], references: [id])
}
