generator client {

    provider    = "prisma-client-js"
    output      = "../../node_modules/@prisma/pgsql/client"
}

datasource db {

    provider    = "postgresql"
    url         = env ("PGSQL_URI")
}

model User {

    @@map ("users")

    id          String      @id @default (uuid ())
    name        String      @unique
    email       String      @unique
    password    String
    created_at  DateTime    @default (now ())
    updated_at  DateTime    @updatedAt
    deleted_at  DateTime?
}
