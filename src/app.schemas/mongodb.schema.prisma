generator client {

    provider    = "prisma-client-js"
    output      = "../../node_modules/@prisma/mongodb/client"
}

datasource db {

    provider    = "mongodb"
    url         = env ("MONGODB_URI")
}

model Log {

    @@map ("logs")

    id          String      @id @default (auto ()) @map ("_id") @db.ObjectId
    level       Level
    state       Json
    created_at  DateTime    @default (now ())
}

enum Level {

    LOG
    FATAL
    ERROR
    WARN
    DEBUG
    VERBOSE
}
